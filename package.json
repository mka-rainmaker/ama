{
  "name": "ama",
  "version": "0.0.1",
  "private": true,
  "description": "Local-first code-intelligence MCP server with deep, language-specific semantic parsing.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "ama": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "node dist/mcp/server.js",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "typescript": "^5.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^24.0.0",
    "vitest": "^3.0.0"
  }
}
