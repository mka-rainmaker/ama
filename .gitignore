# Dependencies
node_modules/

# Build output
dist/
bundle/
*.tsbuildinfo

# npm pack artifacts (release verification)
*.tgz

# Ama local index cache (file-backed SqliteStore for the dev HTTP server)
.ama/

# beads: keep the tracker local. The Dolt DB syncs via refs/dolt/data; the JSONL + audit-log
# exports carry the full backlog (issue text, identities), so they're not published.
.beads/issues.jsonl
.beads/interactions.jsonl
.beads/*.db
.beads/dolt/
.beads/.dolt/

# Editor / OS
.DS_Store
.vscode/
.idea/

# Logs / coverage
*.log
coverage/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# Secrets / local credentials (never commit)
.env
.env.*
.npmrc
